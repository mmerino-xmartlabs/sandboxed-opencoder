#!/bin/bash
set -Eeuo pipefail

readonly ALLOWLIST="/etc/agent/apt-package-allowlist.txt"

if [ "$#" -eq 0 ]; then
  echo "Usage: sudo agent-apt-install <package> [package ...]" >&2
  exit 2
fi

if [ "$(id -u)" -ne 0 ]; then
  echo "Error: agent-apt-install must run through sudo." >&2
  exit 1
fi

for package_name in "$@"; do
  if [[ ! "$package_name" =~ ^[a-z0-9][a-z0-9+._-]*$ ]]; then
    echo "Error: invalid package name '${package_name}'." >&2
    exit 1
  fi

  if ! grep -Fxq "$package_name" "$ALLOWLIST"; then
    echo "Error: '${package_name}' is not in the sandbox apt allowlist." >&2
    echo "Ask the user to approve a one-time Dockerfile/allowlist update before installing it." >&2
    exit 1
  fi
done

apt-get update
apt-get install -y --no-install-recommends "$@"
apt-get clean
rm -rf /var/lib/apt/lists/*
